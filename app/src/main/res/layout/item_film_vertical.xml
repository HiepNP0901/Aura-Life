<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:maxWidth="120dp"
    android:layout_margin="5dp"
    android:background="?android:attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <androidx.constraintlayout.utils.widget.ImageFilterView
        android:id="@+id/posterView"
        android:layout_width="match_parent"
        android:layout_height="140dp"
        android:layout_margin="5dp"
        android:importantForAccessibility="no"
        android:scaleType="centerCrop"
        android:src="@drawable/bg_logo"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:round="16dp" />

    <TextView
        android:id="@+id/nameFilm"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="5dp"
        android:ellipsize="marquee"
        android:gravity="center"
        android:singleLine="true"
        android:text="#name_film"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="@+id/posterView"
        app:layout_constraintStart_toStartOf="@+id/posterView"
        app:layout_constraintTop_toBottomOf="@+id/posterView"
        tools:ignore="HardcodedText" />

    <TextView
        android:id="@+id/details"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="5dp"
        android:gravity="center"
        app:layout_constraintEnd_toEndOf="@+id/nameFilm"
        app:layout_constraintStart_toStartOf="@+id/nameFilm"
        app:layout_constraintTop_toBottomOf="@+id/nameFilm" />
</androidx.constraintlayout.widget.ConstraintLayout>