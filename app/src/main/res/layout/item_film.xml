<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/filmButton"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <ImageView
        android:id="@+id/imageFilm"
        android:layout_width="match_parent"
        android:layout_height="140dp"
        android:src="@drawable/bg_logo"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:ignore="ContentDescription" />

    <TextView
        android:id="@+id/nameFilm"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="10dp"
        android:ellipsize="end"
        android:gravity="center"
        android:lines="2"
        android:maxLines="2"
        android:text="#name_sound"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="@+id/imageFilm"
        app:layout_constraintStart_toStartOf="@+id/imageFilm"
        app:layout_constraintTop_toBottomOf="@+id/imageFilm"
        tools:ignore="HardcodedText" />

    <TextView
        android:id="@+id/currentEpisode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="10dp"
        android:gravity="center"
        android:text="#episodes"
        android:paddingBottom="15dp"
        app:layout_constraintEnd_toEndOf="@+id/nameFilm"
        app:layout_constraintStart_toStartOf="@+id/nameFilm"
        app:layout_constraintTop_toBottomOf="@+id/nameFilm"
        tools:ignore="HardcodedText" />
</androidx.constraintlayout.widget.ConstraintLayout>