<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="5dp"
    android:clickable="true"
    android:focusable="true"
    android:background="?android:attr/selectableItemBackground">

    <ImageView
        android:id="@+id/imageFilm"
        android:layout_width="120dp"
        android:layout_height="160dp"
        android:layout_margin="5dp"
        android:clipToOutline="true"
        android:background="@drawable/rounded"
        android:src="@drawable/bg_logo"
        android:scaleType="centerCrop"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:ignore="ContentDescription,UnusedAttribute" />

    <TextView
        android:id="@+id/nameFilm"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="5dp"
        android:ellipsize="marquee"
        android:gravity="center"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:singleLine="true"
        android:text="#name_film"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="@+id/imageFilm"
        app:layout_constraintStart_toStartOf="@+id/imageFilm"
        app:layout_constraintTop_toBottomOf="@+id/imageFilm"
        tools:ignore="HardcodedText" />

    <TextView
        android:id="@+id/currentEpisode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="5dp"
        android:gravity="center"
        android:text="#episodes"
        app:layout_constraintEnd_toEndOf="@+id/nameFilm"
        app:layout_constraintStart_toStartOf="@+id/nameFilm"
        app:layout_constraintTop_toBottomOf="@+id/nameFilm"
        tools:ignore="HardcodedText" />
</androidx.constraintlayout.widget.ConstraintLayout>