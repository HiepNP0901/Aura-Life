<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="20dp">

    <androidx.constraintlayout.utils.widget.ImageFilterView
        android:id="@+id/navProfilePic"
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:contentDescription="@string/profile"
        android:src="@drawable/ic_profile"
        app:round="250dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/navEmail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/example_email"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="@+id/navProfilePic"
        app:layout_constraintStart_toStartOf="@+id/navProfilePic"
        app:layout_constraintTop_toBottomOf="@+id/navProfilePic" />

</androidx.constraintlayout.widget.ConstraintLayout>
