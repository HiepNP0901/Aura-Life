<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/splash">

    <fragment
        android:id="@+id/splash"
        android:name="com.drs.auralife.presentation.splash.SplashFragment"
        android:label="Splash"
        tools:layout="@layout/activity_splash_screen">
        <action
            android:id="@+id/action_splash_to_onboarding"
            app:destination="@id/onboarding"
            app:popUpTo="@id/splash"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_splash_to_home"
            app:destination="@id/home"
            app:popUpTo="@id/splash"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/onboarding"
        android:name="com.drs.auralife.presentation.onboarding.OnboardingFragment"
        android:label="Onboarding"
        tools:layout="@layout/activity_onboarding">
        <action
            android:id="@+id/action_onboarding_to_home"
            app:destination="@id/home"
            app:popUpTo="@id/splash"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/home"
        android:name="com.drs.auralife.presentation.home.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home" />

    <fragment
        android:id="@+id/explore"
        android:name="com.drs.auralife.presentation.explore.ExploreFragment"
        android:label="Explore"
        tools:layout="@layout/fragment_explore" />

    <fragment
        android:id="@+id/library"
        android:name="com.drs.auralife.presentation.library.LibraryFragment"
        android:label="Library"
        tools:layout="@layout/fragment_library" />

    <fragment
        android:id="@+id/history"
        android:name="com.drs.auralife.presentation.history.HistoryFragment"
        android:label="History"
        tools:layout="@layout/fragment_history" />

    <fragment
        android:id="@+id/login"
        android:name="com.drs.auralife.presentation.login.LoginFragment"
        android:label="Login"
        tools:layout="@layout/activity_login" />

    <fragment
        android:id="@+id/register"
        android:name="com.drs.auralife.presentation.register.RegisterFragment"
        android:label="Register"
        tools:layout="@layout/activity_register" />

    <fragment
        android:id="@+id/film_details"
        android:name="com.drs.auralife.presentation.filmdetails.FilmDetailsFragment"
        android:label="FilmDetails"
        tools:layout="@layout/activity_film_details">
        <argument
            android:name="slug"
            app:argType="string" />
        <action
            android:id="@+id/action_film_details_to_play_film"
            app:destination="@id/play_film" />
        <action
            android:id="@+id/action_film_details_to_login"
            app:destination="@id/login" />
    </fragment>

    <fragment
        android:id="@+id/library_details"
        android:name="com.drs.auralife.presentation.library_details.LibraryDetailsFragment"
        android:label="LibraryDetails"
        tools:layout="@layout/activity_library_details">
        <argument
            android:name="name"
            app:argType="string" />
    </fragment>

    <fragment
        android:id="@+id/payment"
        android:name="com.drs.auralife.presentation.payment.PaymentFragment"
        android:label="Payment"
        tools:layout="@layout/activity_payment" />

    <fragment
        android:id="@+id/play_film"
        android:name="com.drs.auralife.presentation.playfilm.PlayFilmFragment"
        android:label="PlayFilm"
        tools:layout="@layout/activity_play_film">
        <argument
            android:name="slug"
            app:argType="string" />
        <action
            android:id="@+id/action_play_film_to_payment"
            app:destination="@id/payment" />
        <action
            android:id="@+id/action_play_film_to_login"
            app:destination="@id/login" />
    </fragment>

    <fragment
        android:id="@+id/explore_details"
        android:name="com.drs.auralife.presentation.explore_details.ExploreDetailsFragment"
        android:label="ExploreDetails"
        tools:layout="@layout/activity_explore_details">
        <argument
            android:name="slug"
            app:argType="string" />
        <argument
            android:name="name"
            app:argType="string" />
    </fragment>

</navigation>
