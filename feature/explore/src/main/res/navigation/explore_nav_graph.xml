<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/explore_nav_graph"
    app:startDestination="@id/explore">

    <fragment
        android:id="@+id/explore"
        android:name="com.drs.auralife.feature.explore.explore.ExploreFragment"
        android:label="Explore"
        app:route="explore"
        tools:layout="@layout/fragment_explore" />

    <fragment
        android:id="@+id/explore_details"
        android:name="com.drs.auralife.feature.explore.explore_details.ExploreDetailFragment"
        android:label="ExploreDetails"
        app:route="explore_details/{slug}/{name}"
        tools:layout="@layout/fragment_explore_details">
        <argument
            android:name="slug"
            app:argType="string" />
        <argument
            android:name="name"
            app:argType="string" />
    </fragment>
</navigation>